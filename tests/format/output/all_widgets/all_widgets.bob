        <action type="write_pv">
          <description>$(name)</description>
          <pv_name>$(P)$(R)ButtonPanel</pv_name>
          <value>0</value>
        </action>
      </actions>
      <pv_name>SignalX</pv_name>
      <text>Stop</text>
